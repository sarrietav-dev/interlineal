<%= turbo_frame_tag "settings-modal" do %>

  <div class="fixed inset-0 z-50 flex items-end justify-center bg-black/80 p-3 sm:items-center sm:p-4"
       data-controller="modal"
       data-modal-target="backdrop"
       data-action="click->modal#closeOnOutside keydown@document->modal#handleEscape">

    <div class="modal-panel border-yellow-400 max-w-2xl"
         onclick="event.stopPropagation()">

      <div class="mb-6 flex items-start justify-between gap-4 lg:mb-8">
        <h2 class="text-2xl font-bold text-yellow-400 lg:text-3xl text-balance">
          ⚙️ <%= t('settings.title') %>
        </h2>

        <%= button_to "✕",
            close_settings_path,
            method: :get,
            class: "action-button action-button-ghost min-h-11 min-w-11 shrink-0 px-0 text-xl leading-none",
            title: t('settings.close'),
            "aria-label": t('settings.close'),
            data: { turbo_stream: true } %>
      </div>

      <p class="mb-6 text-base text-gray-300 lg:text-lg">
        <%= t('settings.description') %>
      </p>

      <%= render "settings/form", settings: @settings %>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-end lg:mt-12 lg:gap-4">
        <%= link_to "🔄 #{t('settings.reset_defaults')}",
            reset_settings_path,
            class: "action-button action-button-accent w-full sm:w-auto text-sm sm:text-base lg:text-lg",
            data: { "turbo-method": :patch } %>

        <button type="submit" form="settings-form"
            class="action-button action-button-primary w-full sm:w-auto text-sm sm:text-base lg:text-lg">
          ✓ <%= t('settings.done') %>
        </button>
      </div>
    </div>
  </div>

<% end %>
