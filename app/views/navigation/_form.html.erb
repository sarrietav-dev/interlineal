<div id="navigation-form" class="grid grid-cols-1 gap-4 lg:gap-6">
  <!-- Book Selector -->
  <div class="space-y-2">
    <label for="navigation_book_id" class="block text-base font-semibold text-white lg:text-lg">
      <%= t('bible.book') %>:
    </label>
    <%= form_with url: select_book_navigation_path, method: :get, data: { turbo_stream: true } do |book_form| %>
      <%= book_form.select :book_id,
          options_from_collection_for_select(@all_books, :id, :full_name, @book_id),
          { id: "navigation_book_id" },
          {
            class: "control-input text-base lg:text-lg",
            onchange: "event.target.form.requestSubmit()"
          } %>
    <% end %>
  </div>

  <!-- Chapter Selector -->
  <div id="chapter-selector" class="space-y-2">
    <label for="navigation_chapter_number" class="block text-base font-semibold text-white lg:text-lg">
      <%= t('bible.chapter') %>:
    </label>
    <% if @chapters.present? %>
      <%= form_with url: select_chapter_navigation_path, method: :get, data: { turbo_stream: true } do |chapter_form| %>
        <%= hidden_field_tag :book_id, @book_id %>
        <%= chapter_form.select :chapter_number,
            options_from_collection_for_select(@chapters, :chapter_number, :chapter_number, @chapter_number),
            { id: "navigation_chapter_number" },
            {
              class: "control-input text-base lg:text-lg",
              onchange: "event.target.form.requestSubmit()"
            } %>
      <% end %>
    <% else %>
      <select class="control-input text-base text-gray-400 lg:text-lg" disabled>
        <option><%= t('navigation.select_book_first') %></option>
      </select>
    <% end %>
  </div>

  <!-- Verse Selector -->
  <div id="verse-selector" class="space-y-2">
    <label for="navigation_verse_number" class="block text-base font-semibold text-white lg:text-lg">
      <%= t('bible.verse') %>:
    </label>
    <% if @verses.present? %>
      <%= form_with url: navigation_path, method: :patch, data: { turbo: false } do |verse_form| %>
        <%= hidden_field_tag :book_id, @book_id %>
        <%= hidden_field_tag :chapter_number, @chapter_number %>
        <%= verse_form.select :verse_number,
            options_from_collection_for_select(@verses, :verse_number, :verse_number, @verse_number),
            { id: "navigation_verse_number" },
            { class: "control-input text-base lg:text-lg" } %>
        
        <div class="mt-4">
          <%= verse_form.submit t('navigation.navigate'),
              class: "action-button action-button-primary w-full text-sm sm:text-base lg:text-lg" %>
        </div>
      <% end %>
    <% else %>
      <select class="control-input text-base text-gray-400 lg:text-lg" disabled>
        <option><%= t('navigation.select_chapter_first') %></option>
      </select>
    <% end %>
  </div>
</div> 
