<% content_for :title, "Biblia Interlineal - Inicio" %>

<div class="space-y-8 lg:space-y-12">
  <!-- Header Section -->
  <section class="section-shell overflow-hidden py-8 text-center lg:py-14">
    <div class="mx-auto max-w-4xl space-y-4 lg:space-y-6">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-300">
        Estudio Bíblico Interactivo
      </p>
      <h1 class="text-3xl font-bold text-yellow-400 sm:text-5xl lg:text-6xl xl:text-7xl text-balance">
      📖 Biblia Interlineal
      </h1>
      <p class="mx-auto max-w-3xl text-base leading-relaxed text-gray-300 sm:text-lg lg:text-2xl xl:text-3xl">
        Estudio palabra por palabra del Nuevo Testamento<br class="hidden lg:block">
        <span class="text-sky-300">Griego → Español</span> con códigos Strong
      </p>
    </div>
  </section>

  <!-- Quick Start Section -->
  <section class="section-shell p-5 sm:p-6 lg:p-10">
      <h2 class="mb-6 text-center text-2xl font-bold text-white lg:mb-10 lg:text-4xl text-balance">
        🚀 Comenzar Estudio
      </h2>

      <% if @books.present? %>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:gap-8 xl:gap-12">
          <!-- Book Selection -->
          <div class="space-y-4 lg:space-y-6">
            <h3 class="text-xl lg:text-2xl font-semibold text-yellow-400 mb-4">
              📚 Seleccionar Libro
            </h3>
            <% cache('books_list', expires_in: 12.hours) do %>
              <div class="space-y-3">
                <% @books.first(10).each do |book| %>
                  <% cache(book, expires_in: 12.hours) do %>
                    <a href="<%= bible_book_path(book.id) %>"
                       class="block rounded-2xl border border-gray-600 bg-gray-700/80 p-4 transition hover:border-blue-400 hover:bg-blue-600/80 lg:p-5">
                      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <span class="text-lg font-semibold text-white lg:text-xl break-words">
                          <%= book.name %>
                        </span>
                        <span class="text-sm text-gray-300 lg:text-base">
                          <%= book.chapter_count %> <%= book.chapter_count == 1 ? 'capítulo' : 'capítulos' %>
                        </span>
                      </div>
                      <span class="mt-2 block text-sm text-gray-400 lg:text-base">
                        <%= book.abbreviation %> • <%= book.testament == 'NT' ? 'Nuevo Testamento' : 'Antiguo Testamento' %>
                      </span>
                    </a>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>

          <!-- Quick Access -->
          <div class="space-y-4 lg:space-y-6">
            <h3 class="text-xl lg:text-2xl font-semibold text-yellow-400 mb-4">
              ⚡ Acceso Rápido
            </h3>

            <!-- Go to specific verse -->
            <div class="rounded-2xl border border-gray-600 bg-gray-700/80 p-4 lg:p-6">
              <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">
                🎯 Ir a Versículo Específico
              </h4>
              <%= form_with url: root_path, method: :get, local: true, class: "space-y-3" do |f| %>
                <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                  <%= select_tag :book_id,
                      options_from_collection_for_select(@books, :id, :abbreviation, @current_book&.id),
                      {
                        class: "control-input text-sm lg:text-base",
                        prompt: "Libro"
                      } %>
                  <%= number_field_tag :chapter, nil,
                      {
                        class: "control-input text-sm lg:text-base",
                        placeholder: "Cap.…",
                        inputmode: "numeric",
                        min: 1
                      } %>
                  <%= number_field_tag :verse, nil,
                      {
                        class: "control-input text-sm lg:text-base",
                        placeholder: "Ver.…",
                        inputmode: "numeric",
                        min: 1
                      } %>
                </div>
                <%= submit_tag "Ir →",
                    class: "action-button action-button-primary w-full text-sm sm:text-base lg:text-lg" %>
              <% end %>
            </div>

            <!-- Search -->
            <div class="rounded-2xl border border-gray-600 bg-gray-700/80 p-4 lg:p-6">
              <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">
                🔍 Buscar en las Escrituras
              </h4>
              <%= form_with url: bible_search_path, method: :get, local: true, class: "space-y-3" do |f| %>
                <%= text_field_tag :q, nil,
                    {
                      class: "control-input text-base lg:text-lg",
                      placeholder: "Buscar palabras, versículos o Strong's…",
                      autocomplete: "off"
                    } %>
                <%= submit_tag "🔍 Buscar",
                    class: "action-button action-button-success w-full text-sm sm:text-base lg:text-lg" %>
              <% end %>
            </div>

            <!-- Sample verses -->
            <% if @current_verse %>
              <div class="rounded-2xl border border-gray-600 bg-gray-700/80 p-4 lg:p-6">
                <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">
                  📖 Verso de Muestra
                </h4>
                <a href="<%= bible_verse_path(@current_verse.book.id, @current_verse.chapter.chapter_number, @current_verse.verse_number) %>"
                   class="action-button action-button-primary w-full text-sm sm:text-base lg:text-lg">
                   Ver <%= @current_verse.full_reference %> →
                </a>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="text-center py-12 lg:py-20">
          <div class="text-6xl lg:text-8xl mb-6">📚</div>
          <h3 class="text-xl lg:text-3xl font-semibold text-white mb-4">
            No hay datos bíblicos disponibles
          </h3>
          <p class="text-base lg:text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
            Para comenzar a usar la aplicación, necesita importar los datos bíblicos.
            Consulte la documentación para instrucciones sobre cómo cargar los datos.
          </p>
        </div>
      <% end %>
  </section>

  <!-- Features Section -->
  <section class="pb-4 lg:pb-8">
    <h2 class="mb-8 text-center text-2xl font-bold text-white lg:mb-12 lg:text-4xl text-balance">
      ✨ Características Principales
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      <!-- Interlinear Display -->
      <div class="section-shell text-center">
        <div class="text-4xl lg:text-5xl mb-4">🔤</div>
        <h3 class="text-lg lg:text-xl font-semibold text-yellow-400 mb-3">
          Texto Interlineal
        </h3>
        <p class="text-sm lg:text-base text-gray-300">
          Visualización palabra por palabra del griego original con traducción al español
        </p>
      </div>

      <!-- Strong's Concordance -->
      <div class="section-shell text-center">
        <div class="text-4xl lg:text-5xl mb-4">📋</div>
        <h3 class="text-lg lg:text-xl font-semibold text-yellow-400 mb-3">
          Códigos Strong
        </h3>
        <p class="text-sm lg:text-base text-gray-300">
          Definiciones detalladas y análisis gramatical de cada palabra griega
        </p>
      </div>

      <!-- TV Presentation -->
      <div class="section-shell text-center">
        <div class="text-4xl lg:text-5xl mb-4">📺</div>
        <h3 class="text-lg lg:text-xl font-semibold text-yellow-400 mb-3">
          Modo Presentación
        </h3>
        <p class="text-sm lg:text-base text-gray-300">
          Diseño optimizado para pantallas grandes y proyección en iglesias
        </p>
      </div>

      <!-- Search -->
      <div class="section-shell text-center">
        <div class="text-4xl lg:text-5xl mb-4">🔍</div>
        <h3 class="text-lg lg:text-xl font-semibold text-yellow-400 mb-3">
          Búsqueda Avanzada
        </h3>
        <p class="text-sm lg:text-base text-gray-300">
          Busque por palabras en español, griego, o números Strong
        </p>
      </div>

      <!-- Navigation -->
      <div class="section-shell text-center">
        <div class="text-4xl lg:text-5xl mb-4">⌨️</div>
        <h3 class="text-lg lg:text-xl font-semibold text-yellow-400 mb-3">
          Navegación por Teclado
        </h3>
        <p class="text-sm lg:text-base text-gray-300">
          Use las flechas del teclado para navegar rápidamente entre versículos
        </p>
      </div>

      <!-- Responsive -->
      <div class="section-shell text-center">
        <div class="text-4xl lg:text-5xl mb-4">📱</div>
        <h3 class="text-lg lg:text-xl font-semibold text-yellow-400 mb-3">
          Diseño Responsivo
        </h3>
        <p class="text-sm lg:text-base text-gray-300">
          Funciona perfectamente en TV, computadoras, tablets y móviles
        </p>
      </div>
    </div>
  </section>
</div>

<script>
// Quick verse lookup functionality
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('form[action="/"]');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();

      const bookId = document.querySelector('select[name="book_id"]').value;
      const chapter = document.querySelector('input[name="chapter"]').value;
      const verse = document.querySelector('input[name="verse"]').value;

      if (bookId && chapter && verse) {
        window.location.href = `/books/${bookId}/chapters/${chapter}/verses/${verse}`;
      } else {
        alert('Por favor, complete todos los campos (libro, capítulo y versículo)');
      }
    });
  }
});
</script>
