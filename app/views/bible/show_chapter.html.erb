<% content_for :title, @chapter.full_reference %>

<div class="space-y-6 lg:space-y-8">
  <!-- Navigation Header -->
  <nav class="section-shell">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between lg:gap-6">
      <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-center lg:gap-4">
        <!-- Book Info -->
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-xl font-bold text-yellow-400 sm:text-2xl lg:text-3xl text-balance">
            📖 <%= @chapter.full_reference %>
          </h1>
          <span class="inline-flex min-h-10 items-center rounded-full bg-blue-600 px-3 py-1 text-sm font-medium text-white lg:text-base">
            <%= @verse_count %> <%= @verse_count == 1 ? 'versículo' : 'versículos' %>
          </span>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="grid w-full grid-cols-1 gap-3 sm:grid-cols-2 lg:max-w-md lg:gap-4">
        <a href="<%= bible_book_path(@book.id) %>"
           class="action-button action-button-secondary w-full text-sm sm:text-base lg:text-lg">
          📚 Libro
        </a>

        <%= link_to "🔍 Search", bible_search_path,
            class: "action-button action-button-success w-full text-sm sm:text-base lg:text-lg" %>
      </div>
    </div>
  </nav>

  <!-- Chapter Navigation -->
  <nav class="section-shell">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between lg:gap-6">
      <div class="grid w-full grid-cols-1 gap-3 sm:grid-cols-[minmax(0,1fr)_auto] lg:max-w-2xl lg:gap-4">
        <!-- Previous Chapter -->
        <% if @prev_chapter %>
          <%= link_to "◄ Capítulo #{@prev_chapter.chapter_number}",
              bible_chapter_path(@book.id, @prev_chapter.chapter_number),
              class: "action-button w-full bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg",
              title: "Capítulo anterior" %>
        <% else %>
          <button class="action-button w-full cursor-not-allowed bg-gray-700 text-sm text-gray-400 opacity-70 sm:text-base lg:text-lg" disabled>◄ Anterior</button>
        <% end %>

        <!-- Chapter Selector -->
        <%= form_with url: bible_chapter_path(@book.id, 1), method: :get, local: true, class: "w-full sm:w-auto" do |f| %>
          <%= hidden_field_tag :book_id, @book.id %>
          <%= select_tag :chapter_number,
              options_from_collection_for_select(@book.chapters.by_number, :chapter_number, :chapter_number, @chapter.chapter_number),
              {
                class: "control-input text-base lg:text-lg sm:min-w-32",
                onchange: "this.form.submit()",
                "aria-label": "Select Chapter"
              } %>
        <% end %>
      </div>

      <div class="grid w-full grid-cols-1 gap-3 sm:max-w-sm lg:gap-4">
        <!-- Next Chapter -->
        <% if @next_chapter %>
          <%= link_to "Capítulo #{@next_chapter.chapter_number} ►",
              bible_chapter_path(@book.id, @next_chapter.chapter_number),
              class: "action-button w-full bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg",
              title: "Capítulo siguiente" %>
        <% else %>
          <button class="action-button w-full cursor-not-allowed bg-gray-700 text-sm text-gray-400 opacity-70 sm:text-base lg:text-lg" disabled>Siguiente ►</button>
        <% end %>
      </div>
    </div>
  </nav>

  <!-- Verses Grid -->
  <div class="section-shell p-5 sm:p-6 lg:p-8">
    <h2 class="text-xl lg:text-2xl font-bold text-white mb-6 lg:mb-8 text-center">
      Versículos del Capítulo <%= @chapter.chapter_number %>
    </h2>

    <% if @verses.present? %>
      <!-- Verse Grid - Optimized for TV screens -->
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:gap-6 xl:grid-cols-1">
        <% @verses.each do |verse| %>
          <% cache([verse, 'chapter_verse_card'], expires_in: 6.hours) do %>
            <div class="rounded-2xl border border-gray-600 bg-gray-700/80 p-4 transition duration-200 hover:border-blue-400 hover:bg-blue-600/80 lg:p-6 group">
              <div class="flex items-start gap-4">
              <!-- Verse Number -->
              <div class="flex-shrink-0">
                <span class="bg-yellow-600 group-hover:bg-yellow-500 text-yellow-100 font-bold text-lg lg:text-2xl w-10 h-10 lg:w-12 lg:h-12 rounded-full flex items-center justify-center">
                  <%= verse.verse_number %>
                </span>
              </div>

              <!-- Verse Content -->
              <div class="flex-1 min-w-0">
                <div class="mb-3 lg:mb-4">
                  <h3 class="text-base lg:text-lg font-semibold text-yellow-400 mb-2">
                    <%= verse.full_reference %>
                  </h3>

                  <!-- Spanish Text -->
                  <% if verse.spanish_text.present? %>
                    <p class="text-sm lg:text-base xl:text-lg text-white leading-relaxed mb-3">
                      <%= verse.spanish_text %>
                    </p>
                  <% end %>

                  <!-- Word Count Info -->
                  <div class="flex items-center gap-3 text-xs lg:text-sm text-gray-400">
                    <span class="flex items-center gap-1">
                      🔤 <%= verse.word_count %> <%= verse.word_count == 1 ? 'palabra' : 'palabras' %>
                    </span>
                    <% if verse.words.with_strongs.count > 0 %>
                      <span class="flex items-center gap-1">
                        📋 <%= verse.words.with_strongs.count %> Strong's
                      </span>
                    <% end %>
                  </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col gap-2 sm:flex-row lg:gap-3">
                  <%= link_to "📖 Estudiar",
                      bible_verse_path(@book.id, @chapter.chapter_number, verse.verse_number),
                      class: "action-button action-button-primary flex-1 text-sm lg:text-base" %>

                  <%= link_to "📺 Slideshow",
                      bible_slideshow_path(@book.id, @chapter.chapter_number, verse.verse_number),
                      class: "action-button action-button-success flex-1 text-sm lg:text-base",
                      target: "_blank",
                      title: "Abrir en modo presentación" %>
                </div>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <!-- Pagination for large chapters -->
      <% if @verse_count > @page_size %>
        <div class="mt-8 lg:mt-12 flex justify-center">
          <div class="flex flex-wrap items-center justify-center gap-2 lg:gap-4">
            <% if @page > 1 %>
              <%= link_to "◄ Anterior",
                  bible_chapter_path(@book.id, @chapter.chapter_number, page: @page - 1),
                  class: "action-button bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg" %>
            <% end %>

            <span class="rounded-full bg-gray-700/80 px-4 py-2 text-sm text-gray-300 sm:text-base lg:text-lg">
              Página <%= @page %> de <%= (@verse_count.to_f / @page_size).ceil %>
            </span>

            <% if @page < (@verse_count.to_f / @page_size).ceil %>
              <%= link_to "Siguiente ►",
                  bible_chapter_path(@book.id, @chapter.chapter_number, page: @page + 1),
                  class: "action-button bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg" %>
            <% end %>
          </div>
        </div>
      <% end %>

    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12 lg:py-20">
        <div class="text-6xl lg:text-8xl mb-6">📖</div>
        <h3 class="text-xl lg:text-3xl font-semibold text-white mb-4">
          No hay versículos disponibles
        </h3>
        <p class="text-base lg:text-xl text-gray-400">
          Este capítulo no contiene versículos o no se han cargado los datos.
        </p>
      </div>
    <% end %>
  </div>

  <!-- Chapter Statistics -->
  <% cache([@chapter, 'chapter_stats'], expires_in: 6.hours) do %>
    <div class="section-shell p-5 sm:p-6 lg:p-8">
      <h3 class="text-lg lg:text-xl font-semibold text-yellow-400 mb-4 lg:mb-6">
        📊 Estadísticas del Capítulo
      </h3>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        <div class="text-center">
          <div class="text-2xl lg:text-3xl font-bold text-white mb-2">
            <%= @verse_count %>
          </div>
          <div class="text-sm lg:text-base text-gray-400">
            <%= @verse_count == 1 ? 'Versículo' : 'Versículos' %>
          </div>
        </div>

        <div class="text-center">
          <div class="text-2xl lg:text-3xl font-bold text-white mb-2">
            <%= @chapter.word_count %>
          </div>
          <div class="text-sm lg:text-base text-gray-400">
            Palabras
          </div>
        </div>

        <div class="text-center">
          <div class="text-2xl lg:text-3xl font-bold text-white mb-2">
            <%= @chapter.words.with_strongs.count %>
          </div>
          <div class="text-sm lg:text-base text-gray-400">
            Strong's
          </div>
        </div>

        <div class="text-center">
          <div class="text-2xl lg:text-3xl font-bold text-white mb-2">
            <%= @book.chapter_count %>
          </div>
          <div class="text-sm lg:text-base text-gray-400">
            Capítulos en <%= @book.abbreviation %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
// Keyboard navigation for chapter view
document.addEventListener('keydown', function(e) {
  switch(e.key) {
    case 'ArrowLeft':
    case 'p':
    case 'P':
      e.preventDefault();
      <% if @prev_chapter %>
        window.location.href = '<%= bible_chapter_path(@book.id, @prev_chapter.chapter_number) %>';
      <% end %>
      break;
    case 'ArrowRight':
    case 'n':
    case 'N':
      e.preventDefault();
      <% if @next_chapter %>
        window.location.href = '<%= bible_chapter_path(@book.id, @next_chapter.chapter_number) %>';
      <% end %>
      break;
    case '1':
    case '2':
    case '3':
    case '4':
    case '5':
    case '6':
    case '7':
    case '8':
    case '9':
      e.preventDefault();
      const verseNumber = e.key;
      if (verseNumber <= <%= @verse_count %>) {
        window.location.href = '<%= bible_verse_path(@book.id, @chapter.chapter_number, "") %>' + verseNumber;
      }
      break;
  }
});
</script>
