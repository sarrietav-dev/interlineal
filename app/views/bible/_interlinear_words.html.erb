<!-- Interlinear Words Display - Advanced Responsive System for Mobile to 4K -->
<div id="interlinear-words" class="interlinear-grid mt-6 px-1 sm:px-0 lg:mt-8"
     data-controller="word-settings">
  <% words.each_with_index do |word, word_index| %>
    <div class="interlinear-word group flex min-h-[120px] min-w-0 cursor-pointer flex-col justify-between rounded-xl border border-gray-600 bg-gray-700/90 p-3 text-center shadow-sm transition-[background-color,border-color,box-shadow,transform] duration-200 hover:border-blue-400 hover:bg-blue-600/80 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-800 sm:p-4 touch-manipulation"
          <% if word.strong_number.present? %>
            title="<%= t('tv.strongs_help') %>"
            tabindex="0"
         <% else %>
           title="<%= t('messages.no_data') %>"
         <% end %>>

      <!-- Greek Word -->
      <% if word.greek_word.present? %>
        <div class="greek-word mb-2 flex min-w-0 flex-1 items-center justify-center lg:mb-3" data-setting="show_greek">
          <% if word.strong_number.present? %>
            <%= link_to strong_definition_path(word.strong_number),
                class: "block text-sm font-medium leading-tight text-sky-300 transition-colors duration-200 break-words hover:text-sky-200 lg:text-lg xl:text-xl 2xl:text-2xl",
                data: { turbo_frame: "strong-definition-modal" },
                title: "Ver definición Strong's" do %>
              <%= word.greek_word %>
            <% end %>
          <% else %>
            <span class="block text-sm font-medium leading-tight text-sky-300 break-words lg:text-lg xl:text-xl 2xl:text-2xl">
              <%= word.greek_word %>
            </span>
          <% end %>
        </div>
      <% end %>

      <!-- Hebrew Word -->
      <% if word.hebrew_word.present? %>
        <div class="hebrew-word mb-2 flex min-w-0 flex-1 items-center justify-center lg:mb-3" data-setting="show_hebrew">
          <% if word.strong_number.present? %>
            <%= link_to strong_definition_path(word.strong_number),
                class: "block text-sm font-medium leading-tight text-orange-300 transition-colors duration-200 break-words hover:text-orange-200 lg:text-lg xl:text-xl 2xl:text-2xl",
                data: { turbo_frame: "strong-definition-modal" },
                title: "Ver definición Strong's" do %>
              <%= word.hebrew_word %>
            <% end %>
          <% else %>
            <span class="block text-sm font-medium leading-tight text-orange-300 break-words lg:text-lg xl:text-xl 2xl:text-2xl">
              <%= word.hebrew_word %>
            </span>
          <% end %>
        </div>
      <% end %>

      <!-- Spanish Translation -->
      <div class="spanish-word mb-2 flex min-w-0 flex-1 items-center justify-center lg:mb-3" data-setting="show_spanish">
        <% if word.spanish_translation.present? %>
          <span class="block text-sm font-normal leading-tight text-white break-words lg:text-base xl:text-lg 2xl:text-xl">
            <%= word.spanish_translation %>
          </span>
        <% else %>
          <span class="block text-sm lg:text-base xl:text-lg 2xl:text-xl font-normal text-gray-400 leading-tight">—</span>
        <% end %>
      </div>

      <!-- Strong's Number and Grammar -->
      <div class="metadata space-y-1 mt-auto">
        <% if word.strong_number.present? %>
          <div class="strong-number" data-setting="show_strongs">
            <%= link_to strong_definition_path(word.strong_number),
                class: "inline-flex items-center rounded-full bg-yellow-600 px-2.5 py-1 text-xs font-semibold leading-none text-yellow-100 transition-colors duration-200 hover:bg-yellow-500 lg:text-sm",
                data: { turbo_frame: "strong-definition-modal" },
                title: "Ver definición Strong's" do %>
              <%= word.display_strong %>
            <% end %>
          </div>
        <% end %>

        <% if word.greek_grammar.present? %>
          <div class="grammar" data-setting="show_grammar">
            <span class="inline-block bg-gray-600 text-gray-200 text-xs lg:text-sm font-normal px-2 py-1 rounded-md leading-none">
              <%= word.greek_grammar.truncate(10) %>
            </span>
          </div>
        <% elsif word.hebrew_grammar.present? %>
          <div class="grammar" data-setting="show_grammar">
            <span class="inline-block bg-orange-600 text-orange-100 text-xs lg:text-sm font-normal px-2 py-1 rounded-md leading-none">
              <%= word.hebrew_grammar.truncate(10) %>
            </span>
          </div>
        <% end %>

        <% if word.strong&.pronunciation.present? %>
          <div class="pronunciation" data-setting="show_pronunciation">
            <span class="inline-block bg-purple-600 text-purple-100 text-xs lg:text-sm font-normal px-2 py-1 rounded-md leading-none">
              /<%= word.strong.pronunciation %>/
            </span>
          </div>
        <% end %>
      </div>

      <!-- Word Order -->
      <div class="word-order mt-2 lg:mt-3" data-setting="show_word_order">
        <span class="text-xs text-gray-500 font-mono">
          #<%= word.word_order %>
        </span>
      </div>
    </div>
  <% end %>
</div>

<!-- Empty state if no words -->
<% if words.empty? %>
  <div class="text-center py-12 lg:py-16">
    <div class="text-gray-400 text-lg lg:text-2xl">
      <p class="mb-4"><%= t('messages.no_interlinear') %></p>
      <p class="text-base lg:text-xl"><%= t('messages.spanish_only') %></p>
    </div>
  </div>
<% end %>

<style>
  /* ==========================================
     ADVANCED RESPONSIVE INTERLINEAR SYSTEM
     Mobile (320px) to 4K+ (3840px+) Support
     ========================================== */

  /* Base interlinear grid system */
  .interlinear-grid {
    display: grid;
    gap: clamp(0.5rem, 1.2vw, 1.5rem);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 8.75rem), 1fr));
    align-items: start;
    justify-content: center;
    max-width: 100%;
    margin: 0 auto;
  }

  /* Base interlinear word styling with viewport-relative sizing */
  .interlinear-word {
    min-width: 0;
    max-width: none;
    width: 100%;
    min-height: clamp(108px, 12vh, 200px);
    padding: clamp(0.75rem, 1.2vw, 1.25rem);
    border-radius: clamp(0.5rem, 1vw, 1.5rem);
    border-width: clamp(1px, 0.2vw, 3px);
    
    /* Enhanced focus for TV accessibility */
    transition: transform 0.25s ease, background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.25s ease, outline-color 0.1s ease;
  }

  .interlinear-word:focus-visible {
    outline: clamp(2px, 0.4vw, 6px) solid #fbbf24;
    outline-offset: clamp(2px, 0.3vw, 4px);
    transform: scale(1.05);
  }

  @media (hover: hover) and (pointer: fine) {
    .interlinear-word:hover {
      transform: translateY(-2px) scale(1.02);
    }
  }

  /* Dynamic font scaling system */
  .greek-word span,
  .greek-word a {
    font-size: clamp(0.875rem, 3.5vw, 4rem);
    line-height: 1.2;
    font-weight: 500;
  }

  .hebrew-word span,
  .hebrew-word a {
    font-size: clamp(0.875rem, 3.5vw, 4rem);
    line-height: 1.2;
    font-weight: 500;
  }

  .spanish-word span {
    font-size: clamp(0.75rem, 2.8vw, 3.2rem);
    line-height: 1.3;
    font-weight: 400;
  }

  .strong-number span,
  .grammar span {
    font-size: clamp(0.625rem, 1.8vw, 1.8rem);
    padding: clamp(0.25rem, 0.8vw, 1rem) clamp(0.5rem, 1.2vw, 1.5rem);
    border-radius: clamp(0.25rem, 0.5vw, 0.75rem);
  }

  .pronunciation span {
    font-size: clamp(0.625rem, 1.6vw, 1.6rem);
    padding: clamp(0.25rem, 0.8vw, 1rem) clamp(0.5rem, 1.2vw, 1.5rem);
    border-radius: clamp(0.25rem, 0.5vw, 0.75rem);
  }

  .word-order span {
    font-size: clamp(0.5rem, 1.2vw, 1.2rem);
  }

  /* ==========================================
     RESPONSIVE BREAKPOINTS
     ========================================== */

  /* Mobile Portrait (320px - 480px) */
  @media (max-width: 480px) and (orientation: portrait) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
      gap: 0.5rem;
      padding: 0;
    }
    
    .interlinear-word {
      min-height: 90px;
      padding: 0.5rem;
    }
  }

  /* Mobile Landscape (481px - 767px) */
  @media (min-width: 481px) and (max-width: 767px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
      gap: 0.75rem;
    }
  }

  /* Tablet Portrait (768px - 1023px) */
  @media (min-width: 768px) and (max-width: 1023px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
      gap: 1rem;
    }
  }

  /* Desktop/Laptop (1024px - 1365px) */
  @media (min-width: 1024px) and (max-width: 1365px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
      gap: 1.25rem;
    }
  }

  /* Large Desktop (1366px - 1919px) */
  @media (min-width: 1366px) and (max-width: 1919px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
      gap: 1.5rem;
    }
  }

  /* Full HD/1080p (1920px - 2559px) */
  @media (min-width: 1920px) and (max-width: 2559px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
      gap: 1.75rem;
      max-width: 95vw;
    }
    
    .interlinear-word {
      min-height: clamp(140px, 14vh, 180px);
    }
  }

  /* 2K/QHD (2560px - 3199px) */
  @media (min-width: 2560px) and (max-width: 3199px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      gap: 2rem;
      max-width: 92vw;
    }
    
    .interlinear-word {
      min-height: clamp(160px, 15vh, 200px);
      border-radius: 1rem;
    }
  }

  /* Ultrawide/3440x1440 (3200px - 3839px) */
  @media (min-width: 3200px) and (max-width: 3839px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      gap: 2.5rem;
      max-width: 90vw;
    }
    
    .interlinear-word {
      min-height: clamp(180px, 16vh, 220px);
      border-radius: 1.25rem;
    }
  }

  /* 4K and beyond (3840px+) */
  @media (min-width: 3840px) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(21rem, 1fr));
      gap: 3rem;
      max-width: 88vw;
    }
    
    .interlinear-word {
      min-height: clamp(200px, 18vh, 250px);
      border-radius: 1.5rem;
      border-width: 3px;
    }
    
    /* Enhanced font sizes for 4K+ viewing distance */
    .greek-word span,
    .hebrew-word span {
      font-size: clamp(2.5rem, 4vw, 5rem);
      font-weight: 600;
    }
    
    .spanish-word span {
      font-size: clamp(2rem, 3.2vw, 4rem);
      font-weight: 500;
    }
    
    .strong-number span,
    .grammar span {
      font-size: clamp(1.2rem, 2vw, 2.5rem);
      padding: 1rem 1.5rem;
    }
  }

  /* ==========================================
     ASPECT RATIO OPTIMIZATIONS
     ========================================== */

  /* Ultra-wide screens (21:9, 32:9 etc.) */
  @media (min-aspect-ratio: 2.1/1) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(calc(100vw / 12), 1fr));
      max-width: 95vw;
    }
  }

  /* Very tall screens or rotated displays */
  @media (max-aspect-ratio: 0.8/1) {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(calc(100vw / 3), 1fr));
      gap: clamp(1rem, 3vh, 2rem);
    }
    
    .interlinear-word {
      min-height: clamp(80px, 8vh, 120px);
    }
  }

  /* ==========================================
     ACCESSIBILITY & QUALITY ENHANCEMENTS
     ========================================== */

  /* High contrast mode for better TV visibility */
  @media (prefers-contrast: high) {
    .interlinear-word {
      border-width: clamp(2px, 0.3vw, 4px);
      border-color: #ffffff;
      background-color: #000000;
    }
    
    .greek-word span,
    .hebrew-word span {
      color: #ffffff;
      font-weight: 700;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
    }
    
    .spanish-word span {
      color: #ffffff;
      font-weight: 600;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
    }
  }

  /* Reduced motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .interlinear-word {
      transition: none;
    }
    
    .interlinear-word:hover {
      transform: none;
    }
  }

  /* Enhanced text handling for all languages */
  .greek-word span,
  .greek-word a,
  .hebrew-word span,
  .hebrew-word a,
  .spanish-word span {
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
    text-align: center;
    display: block;
    width: 100%;
  }

  /* Improved spacing and layout */
  .greek-word,
  .hebrew-word,
  .spanish-word {
    max-width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .metadata {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(0.25rem, 0.5vw, 0.75rem);
    margin-top: auto;
  }

  .metadata > div {
    display: flex;
    justify-content: center;
  }

  /* Print media optimization */
  @media print {
    .interlinear-grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      page-break-inside: avoid;
    }
    
    .interlinear-word {
      min-height: 120px;
      page-break-inside: avoid;
      border: 1px solid #000;
    }
  }

  /* ==========================================
     RESPONSIVE TEXT ELEMENTS FOR REGULAR VIEWS
     ========================================== */
  
  .responsive-verse-title {
    font-size: clamp(1.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: clamp(-0.02em, 0.05vw, 0.01em);
    text-shadow: clamp(1px, 0.2vw, 3px) clamp(1px, 0.2vw, 3px) clamp(1px, 0.3vw, 6px) rgba(0,0,0,0.5);
  }
  
  .responsive-spanish-text {
    font-size: clamp(1rem, 3vw, 2.5rem);
    line-height: clamp(1.4, 1.6, 1.8);
    text-align: justify;
    letter-spacing: clamp(-0.01em, 0.02vw, 0.005em);
  }

  /* ==========================================
     CONTAINER QUERIES (Future-proofing)
     ========================================== */
  
  /* When browser support improves, this will provide even better responsiveness */
  @supports (container-type: inline-size) {
    .interlinear-container {
      container-type: inline-size;
    }
    
    @container (min-width: 800px) {
      .interlinear-grid {
        grid-template-columns: repeat(auto-fit, minmax(min(25cqi, 300px), 1fr));
      }
    }
  }
</style>
