<% content_for :title, @verse.full_reference %>

<div class="space-y-6 lg:space-y-8"
     data-controller="bible-navigation"
     data-action="keydown@document->bible-navigation#keydown">
  <!-- Navigation Header -->
  <nav class="section-shell">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between lg:gap-6">
      <div class="grid w-full grid-cols-1 gap-3 sm:grid-cols-3 lg:max-w-3xl lg:gap-4">
        <!-- Book Selector -->
        <%= select_tag :book_id,
            options_from_collection_for_select(@all_books, :id, :full_name, @book.id),
            {
              class: "control-input text-base lg:text-lg",
              onchange: "window.location.href = '/books/' + this.value + '/chapters/1/verses/1'",
              "aria-label": "Select Book"
            } %>

        <!-- Chapter Selector -->
        <%= select_tag :chapter_number,
            options_from_collection_for_select(@book.chapters.by_number, :chapter_number, :chapter_number, @chapter.chapter_number),
            {
              class: "control-input text-base lg:text-lg",
              onchange: "window.location.href = '/books/' + #{@book.id} + '/chapters/' + this.value + '/verses/1'",
              "aria-label": "Select Chapter"
            } %>

        <!-- Verse Selector -->
        <%= select_tag :verse_number,
            options_from_collection_for_select(@chapter.verses.by_number, :verse_number, :verse_number, @verse.verse_number),
            {
              class: "control-input text-base lg:text-lg",
              onchange: "window.location.href = '/books/' + #{@book.id} + '/chapters/' + #{@chapter.chapter_number} + '/verses/' + this.value",
              "aria-label": "Select Verse"
            } %>
      </div>

      <!-- Action Buttons -->
      <div class="grid w-full grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4 lg:max-w-3xl lg:gap-4">
        <%= link_to "📺 #{t('bible.slideshow')}", bible_slideshow_path(@book.id, @chapter.chapter_number, @verse.verse_number),
            class: "action-button action-button-primary w-full text-sm sm:text-base lg:text-lg",
            target: "_blank",
            title: t('slideshow.fullscreen'),
            data: { nav: "slideshow" } %>

        <%= link_to "🔍 #{t('bible.search')}", bible_search_path,
            class: "action-button action-button-success w-full text-sm sm:text-base lg:text-lg" %>

        <%= link_to "⚙️ #{t('settings.button')}",
            settings_path(verse_id: @verse.id),
            data: { turbo_frame: "settings-modal" },
            class: "action-button action-button-secondary w-full text-sm sm:text-base lg:text-lg" %>

        <%= link_to "📖 #{t('bible.navigation')}",
            navigation_path,
            data: { turbo_frame: "navigation-modal" },
            class: "action-button w-full bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg" %>
      </div>
    </div>
  </nav>

  <!-- Main Verse Display -->
  <div class="section-shell p-5 sm:p-6 lg:p-8">
    <!-- Verse Reference -->
    <h1 class="responsive-verse-title text-yellow-400 text-center mb-6 lg:mb-8">
      <%= @verse.full_reference %>
    </h1>

    <!-- Spanish Text Display -->
    <% if @spanish_text.present? %>
      <% cache([@verse, 'spanish_text'], expires_in: 1.hour) do %>
        <div class="mb-6 border-l-4 border-yellow-400 bg-gray-700/80 p-4 sm:p-5 lg:mb-8 lg:p-6 rounded-r-xl">
          <p class="responsive-spanish-text text-white">
            <%= @spanish_text %>
          </p>
        </div>
      <% end %>
    <% end %>

    <!-- Interlinear Display -->
    <div class="interlinear-container" id="interlinear-display">
      <% cache([@verse, 'interlinear', @settings], expires_in: 1.hour) do %>
        <%= render 'interlinear_words', words: @words, settings: @settings %>
      <% end %>
    </div>
  </div>

  <!-- Navigation Controls -->
  <nav class="section-shell">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between lg:gap-6">
      <div class="grid w-full grid-cols-1 gap-3 sm:grid-cols-2 lg:max-w-2xl lg:gap-4">
        <!-- Previous Controls -->
        <% if @prev_verse %>
          <%= link_to "◄ #{t('bible.verse')} #{@prev_verse.verse_number}",
              bible_verse_path(@book.id, @chapter.chapter_number, @prev_verse.verse_number),
              class: "action-button w-full bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg",
              title: t('navigation.previous_verse'),
              accesskey: "p",
              data: {
                nav: "prev",
                turbo_frame: "verse-content"
              } %>
        <% elsif @prev_chapter %>
          <% last_verse = @prev_chapter.verses.by_number.last %>
          <%= link_to "◄ #{@prev_chapter.chapter_number}:#{last_verse.verse_number}",
              bible_verse_path(@book.id, @prev_chapter.chapter_number, last_verse.verse_number),
              class: "action-button w-full bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg",
              title: "Previous chapter",
              accesskey: "p" %>
        <% else %>
          <button class="action-button w-full cursor-not-allowed bg-gray-700 text-sm text-gray-400 opacity-70 sm:text-base lg:text-lg" disabled>◄ <%= t('navigation.previous') %></button>
        <% end %>

        <!-- Chapter View -->
        <%= link_to "📖 #{t('bible.chapter')} #{@chapter.chapter_number}",
            bible_chapter_path(@book.id, @chapter.chapter_number),
            class: "action-button action-button-secondary w-full text-sm sm:text-base lg:text-lg",
            title: t('navigation.view_chapter') %>
      </div>

      <div class="grid w-full grid-cols-1 gap-3 sm:max-w-sm lg:gap-4">
        <!-- Next Controls -->
        <% if @next_verse %>
          <%= link_to "#{t('bible.verse')} #{@next_verse.verse_number} ►",
              bible_verse_path(@book.id, @chapter.chapter_number, @next_verse.verse_number),
              class: "action-button w-full bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg",
              title: t('navigation.next_verse'),
              accesskey: "n",
              data: {
                nav: "next",
                turbo_frame: "verse-content"
              } %>
        <% elsif @next_chapter %>
          <%= link_to "#{@next_chapter.chapter_number}:1 ►",
              bible_verse_path(@book.id, @next_chapter.chapter_number, 1),
              class: "action-button w-full bg-purple-600 text-sm text-white hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 sm:text-base lg:text-lg",
              title: "Next chapter",
              accesskey: "n" %>
        <% else %>
          <button class="action-button w-full cursor-not-allowed bg-gray-700 text-sm text-gray-400 opacity-70 sm:text-base lg:text-lg" disabled><%= t('navigation.next') %> ►</button>
        <% end %>
      </div>
    </div>
  </nav>
</div>

<!-- Strong's Definition Modal Frame -->
<%= turbo_frame_tag "strong-definition-modal" %>

<!-- Settings Modal Frame -->
<%= turbo_frame_tag "settings-modal" %>

<!-- Navigation Modal Frame -->
<%= turbo_frame_tag "navigation-modal" %>
