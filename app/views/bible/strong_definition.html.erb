<%= turbo_frame_tag "strong-definition-modal" do %>
  <% if @strong %>
    <% cache([@strong, 'strong_definition', @verses_with_word.to_a], expires_in: 6.hours) do %>
      <div class="fixed inset-0 z-50 flex items-end justify-center bg-black/80 p-3 sm:items-center sm:p-4"
           data-controller="modal"
           data-modal-target="backdrop"
           data-action="click->modal#closeOnOutside keydown@document->modal#handleEscape">

        <div class="modal-panel border-yellow-400 max-w-4xl"
             onclick="event.stopPropagation()">

          <div class="mb-4 flex items-start justify-between gap-4 border-b border-gray-600 pb-4 lg:mb-6 lg:pb-6">
            <div>
              <h2 class="mb-2 text-xl font-bold text-yellow-400 lg:text-3xl text-balance">
              Strong's <%= @strong.display_number %>
              </h2>
              <h3 class="mb-2 text-lg font-semibold text-sky-300 lg:text-2xl break-words">
              <%= @strong.greek_word %>
              </h3>
              <% if @strong.pronunciation.present? %>
                <p class="text-base italic text-gray-300 lg:text-xl break-words">
                  Pronunciación: <%= @strong.pronunciation %>
                </p>
              <% end %>
            </div>

            <%= link_to "✕",
              "#",
              class: "action-button action-button-ghost min-h-11 min-w-11 shrink-0 px-0 text-xl leading-none",
              title: "Cerrar",
              "aria-label": "Cerrar definición Strong's",
              data: { action: "click->modal#close" } %>
          </div>

        <!-- Main Definition -->
        <div class="mb-4 lg:mb-6">
          <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">Definición:</h4>
          <div class="text-base lg:text-lg text-gray-200 leading-relaxed space-y-2">
            <% if @strong.definition.present? %>
              <p><%= @strong.definition %></p>
            <% end %>
            <% if @strong.definition2.present? %>
              <p class="text-gray-300"><%= @strong.definition2 %></p>
            <% end %>
            <% if @strong.definition.blank? && @strong.definition2.blank? %>
              <p class="text-gray-400 italic">No hay definición disponible.</p>
            <% end %>
          </div>
        </div>

        <!-- Grammatical Information -->
        <% if @strong.part_of_speech.present? %>
          <div class="mb-4 lg:mb-6">
            <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">Información Gramatical:</h4>
            <span class="inline-block bg-blue-600 text-blue-100 px-3 py-1 rounded-lg text-sm lg:text-base font-medium">
              <%= @strong.part_of_speech %>
            </span>
          </div>
        <% end %>

        <!-- Etymology/Derivation -->
        <% if @strong.derivation.present? %>
          <div class="mb-4 lg:mb-6">
            <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">Etimología:</h4>
            <p class="text-base lg:text-lg text-gray-300 leading-relaxed">
              <%= @strong.derivation %>
            </p>
          </div>
        <% end %>

        <!-- Reina Valera 1909 Definition (if available) -->
        <% if @strong.rv1909_definition.present? %>
          <div class="mb-4 lg:mb-6">
            <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">Definición RV1909:</h4>
            <p class="text-base lg:text-lg text-gray-300 leading-relaxed">
              <%= @strong.rv1909_definition %>
            </p>
          </div>
        <% end %>

        <!-- Usage Statistics -->
        <div class="mb-4 lg:mb-6">
          <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">Uso en las Escrituras:</h4>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-gray-700 rounded-lg p-3 lg:p-4">
              <span class="text-sm lg:text-base text-gray-400">Total de apariciones:</span>
              <span class="block text-lg lg:text-xl font-semibold text-white">
                <%= @strong.word_count %> <%= @strong.word_count == 1 ? 'vez' : 'veces' %>
              </span>
            </div>
            <div class="bg-gray-700 rounded-lg p-3 lg:p-4">
              <span class="text-sm lg:text-base text-gray-400">En versículos únicos:</span>
              <span class="block text-lg lg:text-xl font-semibold text-white">
                <%= @verses_with_word.count %> <%= @verses_with_word.count == 1 ? 'versículo' : 'versículos' %>
              </span>
            </div>
          </div>
        </div>

        <!-- Sample Verses -->
        <% if @verses_with_word.present? %>
          <div class="mb-4 lg:mb-6">
            <h4 class="text-lg lg:text-xl font-semibold text-white mb-3">
              Ejemplos de Uso
              <span class="text-sm lg:text-base font-normal text-gray-400">
                (mostrando <%= [@verses_with_word.count, 5].min %> de <%= @verses_with_word.count %>)
              </span>
            </h4>
            <div class="max-h-60 space-y-3 overflow-y-auto pr-1 lg:max-h-80 lg:space-y-4">
              <% @verses_with_word.first(5).each do |verse| %>
                <div class="rounded-xl border border-gray-600 bg-gray-700/80 p-3 lg:p-4">
                  <div class="mb-2 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                    <span class="text-sm font-semibold text-yellow-400 lg:text-base">
                      <%= verse.full_reference %>
                    </span>
                    <a href="<%= bible_verse_path(verse.book.id, verse.chapter.chapter_number, verse.verse_number) %>"
                       class="text-xs text-blue-400 underline hover:text-blue-300 sm:ml-2 lg:text-sm"
                       data-action="click->modal#close">
                      Ver verso →
                    </a>
                  </div>
                  <% if verse.spanish_text.present? %>
                    <p class="text-sm lg:text-base text-gray-200 leading-relaxed">
                      <%= verse.spanish_text.truncate(200) %>
                    </p>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Search Related Words -->
        <div class="text-center mt-4 lg:mt-6 pt-4 lg:pt-6 border-t border-gray-600">
          <a href="<%= bible_search_path(q: @strong.greek_word) %>"
             class="action-button action-button-success w-full text-sm sm:w-auto lg:text-base"
             data-action="click->modal#close">
            🔍 <%= t('strongs.search_related', word: @strong.greek_word) %>
          </a>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="fixed inset-0 z-50 flex items-end justify-center bg-black/80 p-3 sm:items-center sm:p-4"
         data-controller="modal"
         data-modal-target="backdrop"
         data-action="click->modal#closeOnOutside keydown@document->modal#handleEscape">

      <div class="modal-panel border-yellow-400 max-w-2xl"
           onclick="event.stopPropagation()">

        <div class="mb-6 flex items-start justify-between gap-4 lg:mb-8">
          <h2 class="text-2xl font-bold text-yellow-400 lg:text-3xl text-balance">
            ❌ Strong's no encontrado
          </h2>

          <%= link_to "✕",
              "#",
              class: "action-button action-button-ghost min-h-11 min-w-11 shrink-0 px-0 text-xl leading-none",
              title: "Cerrar",
              "aria-label": "Cerrar definición Strong's",
              data: { action: "click->modal#close" } %>
        </div>

        <div class="text-center">
          <p class="text-lg lg:text-xl text-gray-300 mb-6">
            No se encontró la definición Strong's para el número <%= params[:strong_number] %>.
          </p>
          <p class="text-base lg:text-lg text-gray-400">
            Es posible que este número no exista en la base de datos o que haya un error en la referencia.
          </p>
        </div>
      </div>
    </div>
  <% end %>
<% end %> 
